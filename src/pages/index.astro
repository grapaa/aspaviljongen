---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import Hero from '../components/Hero.astro';
import Card from '../components/Card.astro';
import { site } from '../lib/site.config';
import { url } from '../lib/url';
---

<BaseLayout title={`${site.name} — ${site.tagline}`}>
  <Header slot="header" />

  <Hero
    eyebrow="Siden 1898"
    headline="Åspaviljongen"
    headlineAccent="Drammen"
    subtext="Drammens landlige storstue byr på en unik lokasjon, varm atmosfære og retter basert på sesongens beste råvarer."
    primaryCta={{ label: 'Se menyen', href: '/meny' }}
    secondaryCta={{ label: 'Leie lokaler', href: '/leie-lokaler' }}
  />

  <!-- Velkommen -->
  <section class="py-24 bg-background">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-16">
        <h2 class="font-display text-3xl sm:text-4xl font-semibold text-text">Velkommen til oss</h2>
        <p class="mt-4 text-muted max-w-2xl mx-auto">
          Gjennom mer enn 125 år har Åspaviljongen vært et samlingspunkt for Drammen. 
          Gå innom oss for en pust i bakken, delta på et arrangement, eller lei lokalene til ditt neste selskap.
        </p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
        <Card
          icon="🍽️"
          title="Restaurant & Kafé"
          description="Sesongbaserte retter fra kjøkkensjef Jonatan Bukkøy-Tindholm Arntzen. Gode råvarer, rene smaker og estetikk."
          href="/meny"
        />
        <Card
          icon="🎉"
          title="Arrangementer"
          description="Middager, konserter og spesielle kvelder gjennom hele året. Åsfest 2026 kommer i mai!"
          href="/arrangementer"
        />
        <Card
          icon="🏛️"
          title="Leie lokaler"
          description="Åspaviljongen kan leies helt eller delvis til private selskap, møter og seminarer."
          href="/leie-lokaler"
        />
      </div>
    </div>
  </section>

  <!-- Åpningstider -->
  <section class="py-24 bg-surface border-t border-border">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-12">
        <h2 class="font-display text-3xl sm:text-4xl font-semibold text-text">Åpningstider</h2>
        <p class="mt-2 text-accent font-medium italic">Alltid åpent når flagget er heist 🏳️</p>
      </div>

      <div class="grid md:grid-cols-2 gap-8">
        <div class="p-8 rounded-2xl border border-border bg-background">
          <h3 class="font-display text-xl font-semibold text-text mb-4">Mars – April 2026</h3>
          <ul class="space-y-2 text-muted">
            <li class="flex justify-between"><span>Fredag</span><span>12:00 – 17:00</span></li>
            <li class="flex justify-between"><span>Lørdag & Søndag</span><span>11:00 – 17:00</span></li>
          </ul>
          <p class="mt-4 text-sm text-muted/70">Kjøkkenet åpner for lunsj 28. mars</p>
        </div>
        <div class="p-8 rounded-2xl border border-border bg-background">
          <h3 class="font-display text-xl font-semibold text-text mb-4">Mai & Juni 2026</h3>
          <ul class="space-y-2 text-muted">
            <li class="flex justify-between"><span>Fredag</span><span>11:00 – 18:00</span></li>
            <li class="flex justify-between"><span>Lørdag & Søndag</span><span>10:00 – 18:00</span></li>
          </ul>
          <p class="mt-4 text-sm text-muted/70">Kjøkken: fre 12–17, lør/søn 10–17</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Sitat -->
  <section class="py-20 bg-primary">
    <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <blockquote class="font-display text-3xl sm:text-4xl font-semibold text-white mb-6 italic">
        "Du kødder ikke med Åspaviljongen" ⚅
      </blockquote>
      <cite class="text-white/65 text-lg not-italic">— Drammens Tidende</cite>
      <div class="mt-10">
        <a
          href={url('/leie-lokaler')}
          class="inline-flex items-center px-8 py-4 text-sm font-medium bg-white text-primary rounded-full hover:bg-accent-light hover:text-primary-dark transition-all duration-200"
        >
          Send forespørsel →
        </a>
      </div>
    </div>
  </section>

  <Footer slot="footer" />
</BaseLayout>
